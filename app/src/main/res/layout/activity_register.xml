<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- Header xanh chứa Logo -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="#64B5F6"
        android:padding="16dp">

        <ImageView
            android:id="@+id/imgLogoRegister"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/shm_logo" /> <!-- Đảm bảo bạn đã có file shm_logo trong drawable -->
    </RelativeLayout>

    <!-- Card Đăng ký (Khung xanh nhạt) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="30dp"
        android:background="#BBDEFB"
        android:orientation="vertical"
        android:padding="24dp"
        android:elevation="4dp">

        <!-- Ô nhập Email/SĐT -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Email hoặc sdt"
            android:textColor="#333333"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/edtRegisterEmail"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:background="#FFFFFF"
            android:hint="Value"
            android:paddingHorizontal="12dp"
            android:inputType="textEmailAddress" />

        <!-- Ô nhập Password -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Password"
            android:textColor="#333333"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/edtRegisterPassword"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:background="#FFFFFF"
            android:hint="Value"
            android:paddingHorizontal="12dp"
            android:inputType="textPassword" />

        <!-- Dòng chữ "Đã có tài khoản" -->
        <TextView
            android:id="@+id/txtAlreadyHaveAccount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="24dp"
            android:text="Đã có tài khoản"
            android:textColor="#757575"
            android:textSize="14sp" />

        <!-- Nút Register màu đen -->
        <Button
            android:id="@+id/btnRegister"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="16dp"
            android:backgroundTint="#2D2D2D"
            android:text="Register"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />

    </LinearLayout>
</LinearLayout>