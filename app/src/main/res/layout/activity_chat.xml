<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- 1. Header: Nút Back + Tên Shop -->
    <LinearLayout
        android:id="@+id/headerChat"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#64B5F6"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:elevation="4dp">

        <ImageButton
            android:id="@+id/btnBackChat"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="#FFFFFF" />

        <TextView
            android:id="@+id/txtShopName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Tên Shop / Người bán"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- 2. Body: Hiển thị tin nhắn -->
    <!-- Trong thực tế sẽ dùng RecyclerView, ở đây dùng ScrollView + TextView theo ý bạn -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/layoutInput"
        android:layout_below="@id/headerChat"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Tin nhắn mẫu từ Người bán (Bên trái) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_msg_receiver"
                android:padding="12dp"
                android:text="Chào bạn, sản phẩm này vẫn còn hàng nhé!"
                android:textColor="#333333"
                android:layout_marginBottom="8dp"/>

            <!-- Tin nhắn mẫu từ Bạn (Bên phải) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:background="@drawable/bg_msg_sender"
                android:padding="12dp"
                android:text="Dạ cho mình hỏi tình trạng máy thế nào ạ?"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="8dp"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- 3. Footer: Thanh nhập liệu + Nút Gửi -->
    <LinearLayout
        android:id="@+id/layoutInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#FFFFFF"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="8dp"
        android:elevation="8dp">

        <EditText
            android:id="@+id/edtMessage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_search_input"
            android:hint="Nhập tin nhắn..."
            android:minHeight="45dp"
            android:paddingHorizontal="16dp"
            android:textSize="15sp" />

        <ImageButton
            android:id="@+id/btnSend"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_send"
            app:tint="#0A8EFA" />
    </LinearLayout>

</RelativeLayout>