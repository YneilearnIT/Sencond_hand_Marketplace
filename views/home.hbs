<div class="p-4 p-md-5 mb-4 rounded text-center hero-banner shadow-sm" style="background-color: #f8f9fa;">
    <div class="col-md-8 mx-auto py-3">
        <h1 class="display-5 fw-bold text-primary mb-3">SÀN GIAO DỊCH SHM</h1>
        <p class="fs-5 text-dark mb-4">Kết nối người mua và người bán đồ cũ nhanh chóng.</p>
        <a href="/post-ad" class="btn btn-primary btn-lg px-4 rounded-pill shadow">Đăng tin ngay</a>
    </div>
</div>

{{#if user}}
    {{#if viewedItems.length}}
    <div class="d-flex justify-content-between align-items-center mb-3 mt-4">
        <h4 class="fw-bold m-0 text-secondary" style="font-size: 1.2rem;">
            🕒 Sản phẩm bạn vừa xem
        </h4>
    </div>
    <div class="row row-cols-2 row-cols-md-4 g-3 mb-5 pb-4 border-bottom border-2">
        {{#each viewedItems}}
        <div class="col">
            <div class="card h-100 shadow-sm border-0 bg-light">
                <img src="{{this.img}}" class="card-img-top product-img opacity-75" alt="{{this.title}}" style="height: 120px; object-fit: cover;" onerror="this.src='https://via.placeholder.com/300x200?text=SHM+Marketplace'">
                <div class="card-body p-2 d-flex flex-column">
                    <h6 class="card-title fs-6 mb-1 text-truncate">
                        <a href="/product/{{this.id}}" class="text-decoration-none text-dark stretched-link">{{this.title}}</a>
                    </h6>
                    <span class="text-danger fw-bold small">{{this.price}} đ</span>
                </div>
            </div>
        </div>
        {{/each}}
    </div>
    {{/if}}
{{/if}}

<div class="d-flex justify-content-between align-items-center mb-4 mt-4">
    <h2 class="fw-bold m-0">🔥 Sản phẩm nổi bật</h2>
    {{#if is_vip}}
    <span class="badge bg-warning text-dark px-3 py-2 ms-2 rounded-pill shadow-sm animate__animated animate__heartBeat animate__infinite">
        <i class="fas fa-crown me-1 text-danger"></i> VIP
    </span>
{{/if}}
</div>

<div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-3 g-md-4">
    {{#each listings}}
    <div class="col">
        <div class="card h-100 shadow-sm product-card border-0">
            <img src="{{this.img}}" class="card-img-top product-img" alt="{{this.title}}" style="height: 180px; object-fit: cover;" onerror="this.src='https://via.placeholder.com/300x200?text=SHM+Marketplace'">
            <div class="card-body d-flex flex-column">
                <h5 class="card-title fs-6 mb-2">
                    <a href="/product/{{this.id}}" class="text-decoration-none text-dark">{{this.title}}</a>
                </h5>
                <h6 class="text-danger fw-bold mb-3">{{this.price}} đ</h6>
                <div class="mt-auto pt-2 border-top text-muted small d-flex justify-content-between align-items-center mb-3">
                    <span class="badge bg-light text-dark border">Mới: {{this.condition}}%</span>
                    <small><i class="fas fa-map-marker-alt"></i> {{this.location}}</small>
                </div>
                <form action="/cart/add" method="POST" style="position: relative; z-index: 2;">
                    <input type="hidden" name="listing_id" value="{{this.id}}">
                    <button type="submit" class="btn btn-outline-primary btn-sm w-100 fw-bold">Thêm vào giỏ</button>
                </form>
            </div>
        </div>
    </div>
    {{else}}
    <div class="col-12 text-center py-5">
        <p class="text-muted">Chưa có sản phẩm nào được đăng.</p>
    </div>
    {{/each}}
</div>