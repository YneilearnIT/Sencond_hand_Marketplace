<div class="p-4 p-md-5 mb-4 rounded text-center hero-banner shadow-sm" style="background-color: #f8f9fa;">
    <div class="col-md-8 mx-auto py-3">
        <h1 class="display-5 fw-bold text-primary mb-3">SÀN GIAO DỊCH SHM</h1>
        <p class="fs-5 text-dark mb-4">Kết nối người mua và người bán đồ cũ nhanh chóng.</p>
        <a href="/post-ad" class="btn btn-primary btn-lg px-4 rounded-pill shadow">Đăng tin ngay</a>
    </div>
</div>

<div class="mb-4">
    <div class="d-flex gap-2 overflow-auto py-2" style="white-space: nowrap;">
        <a href="/" class="btn btn-outline-primary rounded-pill px-4">Tất cả</a>
        {{#each categories}}
            <a href="/?category={{this.category_id}}" class="btn btn-outline-primary rounded-pill px-4">{{this.category_name}}</a>
        {{/each}}
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-4 mt-2">
    <h3 class="fw-bold m-0">
        {{#if searchKeyword}}
            Kết quả tìm kiếm cho: "<span class="text-primary">{{searchKeyword}}</span>"
        {{else}}
            Sản phẩm nổi bật
        {{/if}}
    </h3>
</div>

<div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-3 g-md-4">
    {{#each listings}}
    <div class="col">
        <div class="card h-100 shadow-sm product-card border-0">
            <img src="{{this.img}}" class="card-img-top product-img" alt="product" style="height: 200px; object-fit: cover;">
            <div class="card-body d-flex flex-column">
                <h5 class="card-title fs-6 mb-2" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                    <a href="/product/{{this.id}}" class="text-decoration-none text-dark stretched-link">{{this.title}}</a>
                </h5>
                <h5 class="text-danger fw-bold mb-3">{{this.price}} đ</h5>
                
                <div class="mt-auto pt-2 border-top text-muted small d-flex justify-content-between align-items-center">
                    <span class="badge bg-light text-dark border"><i class="fas fa-tag"></i> Mới: {{this.condition}}%</span>
                    <span><i class="fas fa-map-marker-alt"></i> {{this.location}}</span>
                </div>
            </div>
        </div>
    </div>
    {{else}}
    <div class="col-12 text-center py-5 w-100">
        <img src="https://cdn-icons-png.flaticon.com/512/6134/6134065.png" alt="No data" width="100" class="mb-3 opacity-50">
        <h5 class="text-muted">Không tìm thấy sản phẩm nào phù hợp.</h5>
        <a href="/" class="btn btn-outline-primary mt-2">Quay lại trang chủ</a>
    </div>
    {{/each}}
</div>