<h4 class="fw-bold mb-4"><i class="fas fa-fire text-danger"></i> Sản phẩm nổi bật</h4>
<div class="row g-4">
    {{#each listings}}
    <div class="col-6 col-md-4 col-lg-3">
        <div class="card h-100 border-0 shadow-sm overflow-hidden" style="border-radius: 12px; transition: 0.3s;">
            <div class="position-relative">
                {{#if this.is_vip}}<span class="badge bg-warning text-dark position-absolute top-0 start-0 m-2 shadow-sm fw-bold"><i class="fas fa-crown"></i> VIP</span>{{/if}}
                
                <img src="{{this.img}}" class="card-img-top" style="height: 180px; object-fit: cover;" onerror="this.src='https://via.placeholder.com/300'">
            </div>
            <div class="card-body p-3 d-flex flex-column">
                <h6 class="fw-bold text-dark text-truncate mb-1">{{this.title}}</h6>
                <p class="text-danger fw-bold mb-2 fs-5">{{this.price}} đ</p>
                <div class="d-flex justify-content-between small text-muted mb-3 border-top pt-2">
                    <span>Mới: {{this.condition_percentage}}%</span>
                    <span><i class="fas fa-map-marker-alt"></i> {{this.location_gps}}</span>
                </div>
                
                <div class="d-grid gap-2 mt-auto">
                    <a href="/product/{{this.id}}" class="btn btn-outline-primary btn-sm rounded-pill fw-bold py-2">
                        <i class="fas fa-eye"></i> Xem chi tiết
                    </a>
                    
                    <button onclick="saveProduct({{this.id}})" class="btn btn-outline-danger btn-sm rounded-pill fw-bold">
                        <i class="far fa-heart"></i> Quan tâm
                    </button>
                </div>
            </div>
        </div>
    </div>
    {{/each}}
</div>

<script>
async function saveProduct(id) {
    const res = await fetch('/cart/add', { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({listing_id:id}) });
    const data = await res.json();
    if(data.success) { Swal.fire('Thành công', 'Đã lưu sản phẩm!', 'success').then(()=>location.reload()); }
    else { window.location.href='/login'; }
}
</script>

<style>
    .card:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important; }
</style>