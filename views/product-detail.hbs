<div class="container mt-5">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">Trang chủ</a></li>
            <li class="breadcrumb-item active" aria-current="page">Chi tiết sản phẩm</li>
        </ol>
    </nav>

    <div class="row bg-white p-4 rounded shadow-sm border mt-3">
        <div class="col-md-5 text-center mb-4 mb-md-0">
            <img src="{{product.img}}" alt="{{product.title}}" class="img-fluid rounded border" style="max-height: 400px; object-fit: cover;" onerror="this.src='https://via.placeholder.com/400x400?text=SHM+Marketplace'">
        </div>

        <div class="col-md-7">
            <h2 class="fw-bold text-dark mb-3">{{product.title}}</h2>
            <h3 class="text-danger fw-bold mb-4">{{product.price}} VNĐ</h3>
            
            <ul class="list-unstyled mb-4 text-muted">
                <li class="mb-2"><i class="fas fa-user-tag me-2 text-primary"></i> <strong>Người bán:</strong> {{product.seller_name}}</li>
                <li class="mb-2"><i class="fas fa-map-marker-alt me-2 text-danger"></i> <strong>Khu vực:</strong> {{product.location}}</li>
                <li class="mb-2"><i class="fas fa-certificate me-2 text-success"></i> <strong>Độ mới:</strong> {{product.condition}}%</li>
            </ul>

            <div class="mb-4">
                <h5 class="fw-bold">Mô tả sản phẩm:</h5>
                <p class="text-dark bg-light p-3 rounded border" style="white-space: pre-wrap;">{{product.description}}</p>
            </div>

            <div class="d-flex gap-3 mt-4">
                <form action="/cart/add" method="POST" class="w-50">
                    <input type="hidden" name="listing_id" value="{{product.id}}">
                    <button type="submit" class="btn btn-warning btn-lg w-100 fw-bold">
                        <i class="fas fa-cart-plus me-2"></i> Thêm vào giỏ
                    </button>
                </form>
                <button class="btn btn-success btn-lg w-50 fw-bold" 
    onclick="Swal.fire({
        title: 'Đã gửi!',
        text: 'Tin nhắn của bạn đã được gửi đến người bán an toàn.',
        icon: 'success',
        confirmButtonColor: '#198754'
    })">
    <i class="fas fa-comments me-2"></i> Chat với người bán
</button>
            </div>
        </div>
    </div>
</div>