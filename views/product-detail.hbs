<div class="container mt-4 mb-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/" class="text-decoration-none">Trang chủ</a></li>
            <li class="breadcrumb-item active" aria-current="page">Chi tiết sản phẩm</li>
        </ol>
    </nav>

    <div class="card shadow-sm border-0">
        <div class="card-body p-4">
            <div class="row">
                <div class="col-md-6 mb-4 mb-md-0 text-center">
                    <div class="bg-light rounded d-flex align-items-center justify-content-center p-2" style="height: 400px;">
                        <img src="{{product.img}}" class="img-fluid rounded" style="max-height: 100%; object-fit: contain;" alt="{{product.title}}">
                    </div>
                </div>

                <div class="col-md-6 d-flex flex-column">
                    <h2 class="fw-bold mb-2">{{product.title}}</h2>
                    <h3 class="text-danger fw-bold mb-4">{{product.price}} đ</h3>

                    <div class="bg-light p-3 rounded mb-4">
                        <div class="d-flex align-items-center mb-3">
                            <div class="bg-secondary text-white rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px;">
                                <i class="fas fa-user"></i>
                            </div>
                            <div>
                                <p class="mb-0 text-muted" style="font-size: 0.85rem;">Người bán</p>
                                <h6 class="mb-0 fw-bold">{{product.seller_name}}</h6>
                            </div>
                        </div>
                        
                        <div class="d-flex align-items-center mb-3">
                            <div class="text-danger fs-4 me-3 text-center" style="width: 40px;"><i class="fas fa-map-marker-alt"></i></div>
                            <div>
                                <p class="mb-0 text-muted" style="font-size: 0.85rem;">Khu vực</p>
                                <h6 class="mb-0 fw-bold">{{product.location_gps}}</h6>
                            </div>
                        </div>

                        <div class="d-flex align-items-center">
                            <div class="text-success fs-4 me-3 text-center" style="width: 40px;"><i class="fas fa-box-open"></i></div>
                            <div>
                                <p class="mb-0 text-muted" style="font-size: 0.85rem;">Tình trạng</p>
                                <h6 class="mb-0 fw-bold">Mới {{product.condition_percentage}}%</h6>
                            </div>
                        </div>
                    </div>

                    <div class="mt-auto">
                        <div class="row g-2">
                            <div class="col-6">
                                <button class="btn btn-outline-danger w-100 fw-bold py-2 btn-add-cart" data-id="{{product.listing_id}}">
                                    <i class="far fa-heart me-1"></i> Quan tâm
                                </button>
                            </div>
                            <div class="col-6">
                                <button class="btn btn-success w-100 fw-bold py-2 btn-chat" data-lid="{{product.listing_id}}" data-sid="{{product.seller_id}}">
                                    <i class="fas fa-comment-dots me-1"></i> GỌI NGƯỜI BÁN
                                </button>
                            </div>
                        </div>

                        <div class="mt-3">
                            {{#if user}}
                                <button class="btn btn-outline-danger w-100 fw-bold" id="btn-report-product" data-id="{{product.listing_id}}">
                                    🚩 Báo cáo sản phẩm vi phạm
                                </button>
                            {{else}}
                                <button class="btn btn-outline-secondary w-100 fw-bold" onclick="Swal.fire('Oop!', 'Vui lòng đăng nhập để báo cáo sản phẩm này nhé!', 'info').then(() => window.location.href='/login')">
                                    🚩 Đăng nhập để báo cáo
                                </button>
                            {{/if}}
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0 mt-4">
        <div class="card-header bg-white border-bottom-0 pt-4 pb-0">
            <h5 class="fw-bold"><i class="fas fa-info-circle me-2 text-primary"></i>Mô tả chi tiết</h5>
        </div>
        <div class="card-body">
            <div class="p-3 bg-light rounded text-secondary" style="white-space: pre-wrap; font-size: 0.95rem; line-height: 1.6;">{{product.description}}</div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
document.addEventListener('DOMContentLoaded', () => {
    
    // 1. CHỨC NĂNG LƯU QUAN TÂM
    document.querySelectorAll('.btn-add-cart').forEach(btn => {
        btn.addEventListener('click', async (e) => {
            const id = e.currentTarget.getAttribute('data-id');
            try {
                const res = await fetch('/cart/add', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ listing_id: id })
                });
                const data = await res.json();
                
                if (data.success) {
                    Swal.fire({ 
                        icon: 'success', 
                        title: 'Đã lưu!', 
                        text: 'Sản phẩm đã được thêm vào mục Quan tâm', 
                        timer: 1500, 
                        showConfirmButton: false 
                    }).then(() => location.reload());
                } else if (data.redirect) {
                    window.location.href = data.redirect;
                } else {
                    Swal.fire('Lỗi', data.message || 'Không thể thao tác', 'error');
                }
            } catch (err) {
                Swal.fire('Lỗi', 'Mất kết nối với máy chủ!', 'error');
            }
        });
    });

    // 2. CHỨC NĂNG CHAT VỚI NGƯỜI BÁN
    document.querySelectorAll('.btn-chat').forEach(btn => {
        btn.addEventListener('click', async (e) => {
            const lid = e.currentTarget.getAttribute('data-lid');
            const sid = e.currentTarget.getAttribute('data-sid');
            try {
                const res = await fetch('/chat/start', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ listing_id: lid, seller_id: sid })
                });
                const data = await res.json();
                
                if (data.success) {
                    window.location.href = data.redirect;
                } else if (data.redirect) {
                    window.location.href = data.redirect;
                } else {
                    Swal.fire('Lỗi', data.message || 'Không thể bắt đầu chat', 'error');
                }
            } catch (err) {
                Swal.fire('Lỗi', 'Mất kết nối với máy chủ!', 'error');
            }
        });
    });

    // 3. CHỨC NĂNG BÁO CÁO SẢN PHẨM
    const btnReport = document.getElementById('btn-report-product');
    if(btnReport) {
        btnReport.addEventListener('click', function() {
            const listingId = this.getAttribute('data-id');
            Swal.fire({
                title: 'Báo cáo sản phẩm',
                input: 'textarea',
                inputLabel: 'Lý do (Hàng giả, lừa đảo, cấm bán...)',
                inputPlaceholder: 'Nhập lý do chi tiết...',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                confirmButtonText: 'Gửi báo cáo',
                cancelButtonText: 'Hủy'
            }).then(async (result) => {
                if (result.isConfirmed) {
                    if(!result.value.trim()) return Swal.fire('Lỗi', 'Vui lòng nhập lý do!', 'error');
                    
                    try {
                        const res = await fetch('/report-listing', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ listing_id: listingId, reason: result.value.trim() })
                        });
                        const data = await res.json();
                        
                        if(data.success) {
                            Swal.fire('Thành công', 'Đã gửi báo cáo cho Admin xử lý.', 'success');
                        } else {
                            Swal.fire('Lỗi', data.message || 'Có lỗi xảy ra, vui lòng thử lại!', 'error');
                        }
                    } catch (err) {
                        Swal.fire('Lỗi', 'Không thể kết nối đến Server', 'error');
                    }
                }
            });
        });
    }
});
</script>