<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Tin đăng của tôi</h2>
        <a href="/post-ad" class="btn btn-warning fw-bold rounded-pill shadow-sm">
            <i class="fas fa-plus-circle me-1"></i> Đăng tin mới
        </a>
    </div>

    <div class="row">
        {{#if myListings.length}}
            {{#each myListings}}
            <div class="col-12 mb-3">
                <div class="card shadow-sm border-0 rounded-3 overflow-hidden">
                    <div class="card-body d-flex align-items-center p-3">
                        <img src="{{this.img}}" alt="{{this.title}}" class="rounded" style="width: 100px; height: 100px; object-fit: cover;">
                        
                        <div class="flex-grow-1 ms-4">
                            <h5 class="fw-bold mb-1">{{this.title}}</h5>
                            <p class="text-primary fw-bold fs-5 mb-0">{{this.price}} đ</p>
                            <span class="badge bg-light text-secondary border">ID: {{this.id}}</span>
                        </div>

                        <div class="text-end d-flex flex-column gap-2">
                          {{#if this.is_vip}}
    <button class="btn btn-warning text-dark fw-bold px-3 py-2 disabled shadow-sm">
        <i class="fas fa-crown me-1"></i> Đang ưu tiên
    </button>
{{else}}
    <a href="/promote/{{#if this.id}}{{this.id}}{{else}}{{this.listing_id}}{{/if}}" class="btn btn-outline-warning fw-bold px-3 py-2 shadow-sm">
        <i class="fas fa-rocket me-1"></i> Mua ưu tiên
    </a>
{{/if}}
                            
                            <button class="btn btn-outline-danger btn-sm border-0" onclick="deleteListing({{this.id}})">
                                <i class="fas fa-trash-alt me-1"></i> Xóa tin
                            </button>
                        </div>
                    </div>
                </div>
            </div>
            {{/each}}
        {{else}}
            <div class="col-12 text-center py-5">
                <div class="display-1 text-muted mb-3"><i class="fas fa-box-open"></i></div>
                <h4 class="text-secondary">Bạn chưa có tin đăng nào.</h4>
                <a href="/post-ad" class="btn btn-primary mt-3">Đăng tin ngay thôi!</a>
            </div>
        {{/if}}
    </div>
</div>
<button onclick="deleteListing({{this.id}})" class="btn btn-link text-danger p-0">
    <i class="fas fa-trash me-1"></i> Xóa tin
</button>
<script>
async function deleteListing(id) {
    const result = await Swal.fire({
        title: 'Xóa tin này?',
        text: "Tin đăng của bạn sẽ bị gỡ bỏ khỏi hệ thống!",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#d33',
        cancelButtonText: 'Hủy',
        confirmButtonText: 'Đồng ý xóa'
    });

    if (result.isConfirmed) {
        try {
            const res = await fetch('/delete-listing', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ listing_id: id }) // Gửi ID tin cần xóa
            });
            const data = await res.json();

            if (data.success) {
                await Swal.fire('Thành công!', 'Tin đăng đã được xóa.', 'success');
                location.reload(); // LOAD LẠI TRANG ĐỂ TIN BIẾN MẤT
            } else {
                Swal.fire('Lỗi', 'Không thể xóa tin lúc này!', 'error');
            }
        } catch (err) {
            Swal.fire('Lỗi', 'Mất kết nối với máy chủ!', 'error');
        }
    }
}
</script>