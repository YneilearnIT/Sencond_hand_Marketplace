    <script>
        document.querySelectorAll('form[action="/cart/add"]').forEach(form => {
            form.addEventListener('submit', async (e) => {
                e.preventDefault(); // Phép thuật nằm ở đây: Chặn không cho web tải lại
                
                const formData = new FormData(form);
                const listing_id = formData.get('listing_id');

                try {
                    // Gửi dữ liệu ngầm lên Backend
                    const response = await fetch('/cart/add', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ listing_id })
                    });
                    const data = await response.json();
                    
                    if (data.success) {
                        // 1. Cập nhật con số màu đỏ trên Icon Giỏ hàng
                        const badge = document.getElementById('cart-badge');
                        if (badge) {
                            badge.innerText = data.cartCount;
                        } else {
                            // Nếu trước đó giỏ trống chưa có cục đỏ, thì tự tạo ra
                            const cartIcon = document.getElementById('cart-icon-link');
                            cartIcon.innerHTML += `<span id="cart-badge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.65em;">${data.cartCount}</span>`;
                        }
                        
                        // 2. Bắn cái Popup xanh xanh "Đã thêm thành công" lên
                        const toast = new bootstrap.Toast(document.getElementById('cartToast'));
                        toast.show();
                    }
                } catch (err) {
                    console.error('Lỗi:', err);
                }
            });
        });
    </script>
</body>
