<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SHM Marketplace</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold fs-3" href="/">SHM</a>
            
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link text-white" href="/post-ad"><i class="fas fa-plus-circle"></i> Đăng tin ngay</a>
                    </li>
                </ul>
                
                <form class="d-flex mx-auto w-50" action="/" method="GET">
                    <input class="form-control me-2 rounded-pill border-0 px-4" type="search" name="search" placeholder="Bạn muốn tìm mua gì hôm nay?" value="{{searchKeyword}}">
                    <button class="btn btn-warning rounded-pill px-4 fw-bold text-dark" type="submit"><i class="fas fa-search"></i></button>
                </form>

                <div class="d-flex align-items-center gap-3 ms-auto mt-3 mt-lg-0">
                    {{#if user}}
                        <div class="dropdown">
                            <a class="btn btn-outline-light dropdown-toggle border-0" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="fas fa-user-circle fs-5 align-middle"></i> {{user.full_name}}
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2">
                                <li><a class="dropdown-item py-2" href="#"><i class="fas fa-list me-2"></i> Tin đã đăng</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-danger py-2" href="/logout"><i class="fas fa-sign-out-alt me-2"></i> Đăng xuất</a></li>
                            </ul>
                        </div>
                    {{else}}
                        <a href="/login" class="btn btn-outline-light px-4 rounded-pill">Đăng nhập</a>
                        <a href="/register" class="btn btn-warning px-4 rounded-pill fw-bold text-dark">Đăng ký</a>
                    {{/if}}
                </div>
            </div>
        </div>
    </nav>

    <main class="container py-4">
        {{{body}}}
    </main>

    <footer class="bg-white py-4 mt-5 border-top">
        <div class="container text-center text-muted small">
            <p class="mb-1">© 2026 Sàn giao dịch C2C SHM</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>