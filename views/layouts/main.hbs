<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SHM - Marketplace</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body { background-color: #f4f6f9; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        .navbar { background: #0d6efd !important; padding: 0.8rem 0; }
        .search-group { background: #fff; border-radius: 8px; overflow: hidden; width: 100%; }
        .search-group select { border: none; background: #f8f9fa; border-right: 1px solid #ddd; max-width: 130px; font-size: 0.9rem; }
        .search-group input { border: none; }
        .search-group input:focus { box-shadow: none; }
        .badge-noti { font-size: 0.65rem; position: absolute; top: -5px; right: -5px; }
        .avatar-circle { width: 32px; height: 32px; background: #fff; color: #0d6efd; border-radius: 50%; font-weight: bold; display: flex; align-items: center; justify-content: center; border: 2px solid #fff; text-transform: uppercase; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark sticky-top shadow">
        <div class="container">
            <a class="navbar-brand fw-bold fs-3 d-flex align-items-center" href="/">
                <i class="fas fa-shopping-basket text-warning me-2"></i>SHM
            </a>

            <form class="d-flex flex-grow-1 mx-lg-5" action="/" method="GET">
                <div class="input-group search-group shadow-sm">
                    <select name="category" class="form-select text-muted d-none d-md-block">
                        <option value="">Tất cả</option>
                        {{#each globalCategories}}
                            <option value="{{this.category_id}}" {{#if (eq ../selectedCategory this.category_id)}}selected{{/if}}>{{this.category_name}}</option>
                        {{/each}}
                    </select>
                    <input class="form-control py-2" type="search" name="keyword" placeholder="Bạn tìm gì hôm nay?" value="{{keyword}}">
                    <button class="btn btn-warning px-4" type="submit"><i class="fas fa-search"></i></button>
                </div>
            </form>

            <div class="d-flex align-items-center">
                {{#if user}}
                    <a href="/cart" class="text-white me-3 position-relative"><i class="fas fa-heart fs-5"></i>
                        {{#if cartItemCount}}<span class="badge rounded-pill bg-danger badge-noti">{{cartItemCount}}</span>{{/if}}
                    </a>
                    <a href="/messages" class="text-white me-3 position-relative"><i class="fas fa-comment-dots fs-5"></i></a>
                    <a href="/notifications" class="text-white me-3 position-relative"><i class="fas fa-bell fs-5"></i>
                        {{#if notiItemCount}}<span class="badge rounded-pill bg-danger badge-noti">{{notiItemCount}}</span>{{/if}}
                    </a>
                    <a href="/post-ad" class="btn btn-warning fw-bold btn-sm rounded-pill px-3 me-3 text-dark shadow-sm">Đăng tin</a>
                    
                    <div class="dropdown">
                        <a class="d-flex align-items-center text-white text-decoration-none dropdown-toggle" href="#" data-bs-toggle="dropdown">
                            <div class="avatar-circle me-2">{{substring user.full_name 0 1}}</div>
                            <span class="d-none d-md-inline fw-bold small text-uppercase">{{user.full_name}}</span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end border-0 shadow mt-2">
                            <li><a class="dropdown-item py-2" href="/profile"><i class="fas fa-user-circle me-2 text-primary"></i>Hồ sơ cá nhân</a></li>
                            <li><a class="dropdown-item py-2" href="/my-listings"><i class="fas fa-box me-2 text-success"></i>Tin của tôi</a></li>
                            {{#if isAdmin}}
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item py-2 fw-bold text-danger" href="/admin"><i class="fas fa-user-shield me-2"></i>QUẢN TRỊ VIÊN</a></li>
                            {{/if}}
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item py-2 text-muted" href="/logout"><i class="fas fa-sign-out-alt me-2"></i>Đăng xuất</a></li>
                        </ul>
                    </div>
                {{else}}
                    <a href="/login" class="btn btn-outline-light btn-sm me-2 fw-bold px-3 rounded-pill">Đăng nhập</a>
                    <a href="/register" class="btn btn-warning btn-sm fw-bold px-3 rounded-pill text-dark shadow-sm">Đăng ký</a>
                {{/if}}
            </div>
        </div>
    </nav>
    <div class="container py-4">{{{body}}}</div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</body>
</html>