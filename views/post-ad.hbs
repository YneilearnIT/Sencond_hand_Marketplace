<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-0">
                <div class="card-header bg-primary text-white py-3">
                    <h4 class="mb-0 fw-bold"><i class="fas fa-box-open me-2"></i> Đăng tin bán hàng</h4>
                </div>
                <div class="card-body p-4 p-md-5">
                    
                    <form action="/post-ad" method="POST" enctype="multipart/form-data">
                        
                        <div class="mb-3">
                            <label class="form-label fw-bold">Tên sản phẩm <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" name="title" required>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6 mb-3 mb-md-0">
                                <label class="form-label fw-bold">Giá bán (VNĐ) <span class="text-danger">*</span></label>
                                <input type="number" class="form-control" name="price" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Độ mới (%) <span class="text-danger">*</span></label>
                                <input type="number" class="form-control" name="condition" required min="1" max="100">
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Khu vực giao dịch <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" name="location" required>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Hình ảnh sản phẩm</label>
                            <div class="card p-3 bg-light border-0">
                                <div class="mb-3">
                                    <label class="form-label text-secondary small fw-bold">Cách 1: Tải ảnh lên từ thiết bị của bạn</label>
                                    <input class="form-control border-primary" type="file" name="image_file" accept="image/*">
                                </div>
                                <div class="text-center text-muted small mb-2 fw-bold">- HOẶC -</div>
                                <div>
                                    <label class="form-label text-secondary small fw-bold">Cách 2: Dán đường link ảnh từ web</label>
                                    <input type="text" class="form-control" name="image_url">
                                </div>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Mô tả chi tiết <span class="text-danger">*</span></label>
                            <textarea class="form-control" name="description" rows="5" required></textarea>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 fw-bold py-3 fs-5">
                            <i class="fas fa-paper-plane me-2"></i> Đăng tin ngay
                        </button>
                    </form>
                    
                </div>
            </div>
        </div>
    </div>
</div>