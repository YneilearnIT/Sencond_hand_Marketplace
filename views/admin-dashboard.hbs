<div class="container mt-4">
    <h2 class="fw-bold mb-4 text-uppercase"><i class="fas fa-user-shield me-2"></i>Bảng Điều Khiển Admin</h2>

    {{#if pendingVip.length}}
    <div class="card border-warning mb-5 shadow animate__animated animate__fadeIn">
        <div class="card-header bg-warning text-dark fw-bold d-flex align-items-center">
            <i class="fas fa-coins me-2 fs-4 animate__animated animate__swing animate__infinite"></i> 
            YÊU CẦU DUYỆT VIP MỚI
        </div>
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Khách hàng</th>
                        <th>Sản phẩm</th>
                        <th class="text-center">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each pendingVip}}
                    <tr>
                        <td class="fw-bold">#{{this.listing_id}}</td>
                        <td>{{this.full_name}}</td>
                        <td>{{this.title}}</td>
                        <td class="text-center">
                            <button class="btn btn-success btn-sm fw-bold px-3 shadow-sm" onclick="approveVip({{this.listing_id}})">
                                <i class="fas fa-check-circle me-1"></i> DUYỆT (2K)
                            </button>
                        </td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
    </div>
    {{/if}}
<div class="card mb-4 border-0 shadow-sm">
    <div class="card-body bg-light rounded-3">
        <form action="/admin" method="GET" class="row g-2">
            <div class="col-md-6">
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0"><i class="fas fa-search text-muted"></i></span>
                    <input type="text" name="keyword" class="form-control border-start-0" placeholder="Tìm tên sản phẩm hoặc người đăng..." value="{{adminKeyword}}">
                </div>
            </div>
            <div class="col-md-4">
                <select name="category" class="form-select">
                    <option value="">Tất cả danh mục</option>
                    {{#each globalCategories}}
                        <option value="{{this.category_id}}" {{#if (eq ../adminCategory this.category_id)}}selected{{/if}}>
                            {{this.category_name}}
                        </option>
                    {{/each}}
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-dark w-100 fw-bold">LỌC TIN</button>
            </div>
        </form>
    </div>
</div>
    <div class="card shadow-sm border-0">
        <div class="card-header bg-dark text-white fw-bold">Tất cả sản phẩm trên sàn</div>
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Hình ảnh</th>
                        <th>Tên sản phẩm</th>
                        <th>Loại tin</th>
                        <th>Giá</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each allListings}}
                    <tr>
                        <td><img src="{{this.img}}" width="50" class="rounded shadow-sm"></td>
                        <td><strong>{{this.title}}</strong></td>
                        <td>
                            {{#if this.is_vip}}
                                <span class="badge bg-warning text-dark animate__animated animate__flash animate__infinite animate__slow">
                                    <i class="fas fa-crown me-1"></i> VIP
                                </span>
                            {{else}}
                                <span class="badge bg-light text-muted border">Thường</span>
                            {{/if}}
                        </td>
                        <td class="text-danger fw-bold">{{this.price}} đ</td>
                        <td>
                            <button class="btn btn-outline-danger btn-sm" onclick="deleteProduct({{this.listing_id}})">
                                <i class="fas fa-trash"></i>
                            </button>
                        </td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
    </div>
</div>
{{#if pendingAds.length}}
<div class="card border-info mb-4 shadow-sm animate__animated animate__fadeIn">
    <div class="card-header bg-info text-white fw-bold">
        <i class="fas fa-clipboard-check me-2"></i> CÓ {{pendingAds.length}} TIN MỚI CHỜ DUYỆT NỘI DUNG
    </div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <tbody>
                {{#each pendingAds}}
                <tr>
                    <td>#{{this.listing_id}}</td>
                    <td><strong>{{this.full_name}}</strong></td>
                    <td>{{this.title}}</td>
                    <td class="text-end">
                        <button class="btn btn-outline-primary btn-sm" onclick="approveAd({{this.listing_id}})">
                            Duyệt tin
                        </button>
                    </td>
                </tr>
                {{/each}}
            </tbody>
        </table>
    </div>
</div>
{{/if}}

<script>
// Hàm duyệt tin thường
async function approveAd(id) {
    const res = await fetch('/admin/approve-ad', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({ listing_id: id })
    });
    const data = await res.json();
    if(data.success) {
        Swal.fire('Thành công', 'Tin đã được hiển thị trên trang chủ!', 'success').then(() => location.reload());
    }
}
</script>
<script>
// Hàm xử lý duyệt VIP
// Thay thế hàm approveVip cũ
async function approveVip(id) {
    // Sử dụng SweetAlert2 để tạo popup xác nhận
    const result = await Swal.fire({
        title: 'Xác nhận duyệt VIP?',
        text: `Bạn đã kiểm tra tài khoản và nhận đủ 2.000đ cho tin #${id} chưa?`,
        icon: 'question',
        showCancelButton: true,
        confirmButtonColor: '#198754', // Màu xanh lá thành công
        cancelButtonColor: '#d33',
        confirmButtonText: 'Đã nhận tiền, Duyệt ngay!',
        cancelButtonText: 'Chưa nhận được',
        reverseButtons: true
    });

    if (result.isConfirmed) {
        // Hiện hiệu ứng đang xử lý cho chuyên nghiệp
        Swal.fire({
            title: 'Đang kích hoạt...',
            didOpen: () => { Swal.showLoading(); }
        });

        try {
            const res = await fetch('/admin/approve-vip', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ listing_id: id })
            });
            const data = await res.json();

            if (data.success) {
                await Swal.fire({
                    title: 'Thành công!',
                    text: 'Sản phẩm đã chính thức lên VIP lấp lánh.',
                    icon: 'success',
                    timer: 2000,
                    showConfirmButton: false
                });
                location.reload();
            } else {
                Swal.fire('Lỗi', 'Không thể duyệt lúc này, thử lại sau nhé!', 'error');
            }
        } catch (err) {
            Swal.fire('Lỗi kết nối', 'Server có vẻ đang bận rồi Thế Anh ơi!', 'error');
        }
    }
}
// Hàm xử lý xóa tin đăng
async function deleteProduct(id) {
    if(confirm('Bạn có chắc muốn xóa vĩnh viễn tin đăng này không?')) {
        const res = await fetch('/admin/delete-product', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({ listing_id: id })
        });
        const data = await res.json();
        if(data.success) location.reload();
    }
}
</script>