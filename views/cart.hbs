<div class="container mt-5">
    <h2 class="fw-bold mb-4">Giỏ hàng của bạn</h2>

    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th scope="col" class="ps-4">Sản phẩm</th>
                                    <th scope="col">Giá tiền</th>
                                    <th scope="col" class="text-center">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                {{#each cartItems}}
                                <tr>
                                    <td class="ps-4 py-3">
                                        <div class="d-flex align-items-center">
                                            <img src="{{this.img}}" class="rounded me-3" alt="product" style="width: 60px; height: 60px; object-fit: cover;">
                                            <div>
                                                <h6 class="mb-0 text-dark">{{this.title}}</h6>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="text-danger fw-bold">{{this.price}} đ</span>
                                    </td>
                                    <td class="text-center">
                                        <form action="/cart/remove" method="POST">
                                            <input type="hidden" name="listing_id" value="{{this.id}}">
                                            <button type="submit" class="btn btn-sm btn-outline-danger">Xóa</button>
                                        </form>
                                    </td>
                                </tr>
                                {{else}}
                                <tr>
                                    <td colspan="3" class="text-center py-5">
                                        <img src="https://cdn-icons-png.flaticon.com/512/11329/11329060.png" width="100" class="mb-3 opacity-50">
                                        <h5 class="text-muted">Giỏ hàng đang trống</h5>
                                        <a href="/" class="btn btn-primary mt-2">Quay lại mua sắm</a>
                                    </td>
                                </tr>
                                {{/each}}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        {{#if cartItems.length}}
        <div class="col-lg-4">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3">Tóm tắt đơn hàng</h5>
                    <div class="d-flex justify-content-between mb-3 text-muted">
                        <span>Số lượng sản phẩm:</span>
                        <span>{{cartItems.length}} món</span>
                    </div>
                    <hr>
                  
    Chốt đơn ngay
<button class="btn btn-warning w-100 fw-bold py-3 mt-3 fs-5" 
    onclick="Swal.fire({
        title: 'Sắp ra mắt!',
        text: 'Tính năng thanh toán đang được phát triển. Bạn quay lại sau nhé!',
        icon: 'info',
        confirmButtonText: 'Đã hiểu',
        confirmButtonColor: '#0d6efd'
    })">
    <i class="fas fa-money-check-alt me-2"></i> Chốt đơn ngay
</button>
                </div>
            </div>
        </div>
        {{/if}}
    </div>
</div>