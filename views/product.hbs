<div class="row mt-3">
    <div class="col-md-6 mb-4">
        {{#if images}}
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <img src="{{images.[0].image_url}}" class="img-fluid w-100" alt="Product Image" style="object-fit: contain; max-height: 450px; background-color: #f8f9fa;">
        </div>
        {{else}}
        <div class="card border-0 shadow-sm rounded-4 bg-light d-flex align-items-center justify-content-center" style="height: 450px;">
            <span class="text-muted"><i class="fas fa-image fa-3x mb-2"></i><br>Không có ảnh</span>
        </div>
        {{/if}}
    </div>

    <div class="col-md-6">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/" class="text-decoration-none">Trang chủ</a></li>
                <li class="breadcrumb-item active">{{product.category_name}}</li>
            </ol>
        </nav>

        <h2 class="fw-bold mb-3">{{product.title}}</h2>
        <h2 class="text-danger fw-bold mb-4">{{product.price}} đ</h2>

        <div class="d-flex flex-wrap gap-3 mb-4 text-dark bg-white p-3 rounded-3 shadow-sm border">
            <span class="fs-6"><i class="fas fa-box text-primary"></i> Tình trạng: <strong>Mới {{product.condition_percentage}}%</strong></span>
            <span class="fs-6"><i class="fas fa-map-marker-alt text-danger"></i> Khu vực: <strong>{{product.location_gps}}</strong></span>
        </div>

        <div class="card border-0 bg-light p-3 mb-4 rounded-4 shadow-sm">
            <div class="d-flex align-items-center gap-3">
                <div class="bg-primary text-white rounded-circle d-flex justify-content-center align-items-center" style="width: 55px; height: 55px; font-size: 24px;">
                    <i class="fas fa-user"></i>
                </div>
                <div>
                    <h5 class="mb-1 fw-bold">{{product.seller_name}}</h5>
                    <small class="text-muted">Đánh giá: <strong>{{product.reputation_score}}</strong> <i class="fas fa-star text-warning"></i></small>
                </div>
                <button class="btn btn-primary ms-auto rounded-pill px-4 shadow-sm">
                    <i class="fas fa-comment-dots"></i> Chat ngay
                </button>
            </div>
        </div>

        <h5 class="fw-bold border-bottom pb-2 mb-3">Mô tả sản phẩm</h5>
        <p class="text-secondary lh-lg" style="white-space: pre-wrap;">{{product.description}}</p>
    </div>
</div>